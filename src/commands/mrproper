#!/bin/bash

source buildbox_utils.sh

function help {
	echo "Usage: bbx mrproper <PKG...>"
	echo ""
	echo "Wipe sources and built files for one or more packages (current target)."
	echo "  PKG...   Package name(s) to wipe (glob patterns supported)"
}

case "$1" in
	help|-h|--help) help; exit 0 ;;
esac

if [ $# -lt 1 ]; then
	help >&2
	exit 1
fi
if [ -z "${BB_PROJECT_DIR}" ] || [ ! -d "${BB_PROJECT_DIR}" ]; then
	>&2 echo "Not in a BuildBox project directory"
	exit 1
fi
packages_list=$@
if [ ! -d ${BB_TARGET_SRC_DIR} ]; then
	>&2 echo "No packages pulled for this target yet."
	exit 0
fi

selected_packages=$(bb_find_matching_packages 0 ${packages_list})
if [ "${selected_packages}" == "" ]; then
	>&2 echo "No matching packages !"
	exit 1
fi
bb_confirm "The following packages sources and built files will be removed:\n\t${selected_packages}\nConfirm?"
if [ $? -eq 0 ]; then
	exit 0
fi

# Wipe individual packages
bb_trap_errors_nolog
while read -r line
do
	readarray -d : -t package <<< "${line}"
	pkg_name=${package[0]/$'\n'/}
	bb_wipe_package ${pkg_name}
done < <(echo "${selected_packages}")

exit 0
