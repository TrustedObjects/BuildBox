## @brief Clone a BuildBox project from a remote git repository.
source _pre_cmd

function help {
	>&2 echo "Usage: project_clone <url> [<dir>]"
	>&2 echo ""
	>&2 echo "  url   Git URL of the project to clone"
	>&2 echo "  dir   Local directory name (default: inferred from url)"
}

if [ $# -eq 0 ] || [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
	help
	exit 0
fi

url="$1"
dir="${2:-$(basename "${url}" .git)}"

created_dir=0
if [ ! -d "${dir}" ]; then
	mkdir -p "${dir}"
	created_dir=1
fi

git clone --quiet --recurse-submodules "${url}" "${dir}/.bbx"
if [ $? -ne 0 ]; then
	[ ${created_dir} -eq 1 ] && rmdir "${dir}" 2>/dev/null || true
	>&2 echo "Unable to clone project"
	exit 1
fi

if ! find "${dir}/.bbx" -maxdepth 1 -name "target.*" 2>/dev/null | grep -q .; then
	>&2 echo "Warning: cloned repository does not appear to be a BuildBox profile (no target.* file found)."
fi

echo "Project cloned into ${dir}"
echo "Run 'cd ${dir}' then 'bbx target set <TARGET>' to get started."
