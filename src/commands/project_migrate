## @brief Migrate a BuildBox 1.x project branch to a BuildBox 2.x project.
##
## Takes the legacy central projects repository (where each branch was a
## project profile) and a branch name, and produces a standalone git
## repository suitable for BuildBox 2.x.
##
## What the migration does:
##  - Clones the given branch (preserving its full git history)
##  - Detaches from the legacy remote (standalone repo)
##  - Renames the branch to 'master'
##  - Moves all profile files from the repository root into .bbx/
##  - Moves the packages submodule from 'packages' to '.bbx/packages'
##    (keeping the same remote URL, .gitmodules stays at root)
##  - Creates a root .gitignore covering BuildBox generated directories
##  - Commits all changes as a single migration commit
##
## Usage:
##   project_migrate --url <legacy_repo_url> --branch <branch> [--output <dir>]
##
## Arguments:
##   --url, -u      URL of the legacy BuildBox projects git repository
##   --branch, -b   Branch name (= legacy project name)
##   --output, -o   Output directory name (default: branch name)

function help {
	cat >&2 <<EOF
Usage: project_migrate --url <legacy_url> --branch <branch> [--output <dir>]

  --url, -u      URL of the legacy BuildBox projects git repository
  --branch, -b   Branch name (= legacy project name)
  --output, -o   Output directory name (default: branch name)
  --help, -h     Show this help

Example:
  project_migrate --url ssh://git@server/projects.git --branch my_project
  project_migrate --url ssh://git@server/projects.git --branch my_project --output ~/workspace/my_project
EOF
}

url=""
branch=""
output_dir=""

while [ $# -gt 0 ]; do
	case "$1" in
	--url|-u)
		shift
		url="$1"
		;;
	--branch|-b)
		shift
		branch="$1"
		;;
	--output|-o)
		shift
		output_dir="$1"
		;;
	--help|-h)
		help
		exit 0
		;;
	*)
		>&2 echo "Unknown argument: $1"
		help
		exit 1
		;;
	esac
	shift
done

if [ -z "${url}" ] || [ -z "${branch}" ]; then
	>&2 echo "Error: --url and --branch are required"
	help
	exit 1
fi

output_dir="${output_dir:-${branch}}"

if [ -e "${output_dir}" ]; then
	>&2 echo "Error: '${output_dir}' already exists"
	exit 1
fi

# ---- Step 1: clone the specific branch, preserving history ------------------

echo "Cloning branch '${branch}' from ${url}..."
git clone --single-branch --branch "${branch}" --recurse-submodules "${url}" "${output_dir}"
if [ $? -ne 0 ]; then
	>&2 echo "Error: unable to clone '${url}' (branch: ${branch})"
	rm -rf "${output_dir}" 2>/dev/null
	exit 1
fi

cd "${output_dir}" || { >&2 echo "Error: unable to enter ${output_dir}"; exit 1; }

# ---- Step 2: detach from legacy remote, set branch name to master -----------

git remote remove origin
if [ $? -ne 0 ]; then
	>&2 echo "Warning: unable to remove origin remote"
fi

current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [ "${current_branch}" != "master" ]; then
	git branch -m master
	if [ $? -ne 0 ]; then
		>&2 echo "Error: unable to rename branch '${current_branch}' to 'master'"
		exit 1
	fi
	echo "Branch renamed: ${current_branch} -> master"
fi

# ---- Step 3: gather state before any moves ----------------------------------

# Collect all top-level items tracked by git, excluding:
#   .gitmodules  – must stay at root (git manages it for submodules)
#   .bbx         – our destination
tracked_root_items=$(git ls-files --cached | cut -d/ -f1 | sort -u \
	| grep -v '^\.gitmodules$' \
	| grep -v '^\.bbx$')

# ---- Step 4: create .bbx/ and move content ----------------------------------

mkdir -p .bbx
echo "Moving profile content into .bbx/..."

# Handle packages submodule first, before moving other items.
# git mv on a submodule automatically updates .gitmodules.
has_submodule=0
packages_url=""

if echo "${tracked_root_items}" | grep -qx "packages"; then
	entry_mode=$(git ls-files -s -- packages | awk '{print $1}')
	if [ "${entry_mode}" = "160000" ]; then
		has_submodule=1
		packages_url=$(git config -f .gitmodules submodule.packages.url 2>/dev/null)

		echo "  packages (submodule) -> .bbx/packages"
		# Create placeholder directory so git mv can operate
		mkdir -p .bbx/packages
		rmdir .bbx/packages
		git mv packages .bbx/packages
		if [ $? -ne 0 ]; then
			>&2 echo "Error: unable to move packages submodule to .bbx/packages"
			exit 1
		fi
		# Verify .gitmodules was updated; fix manually if git mv did not do it
		current_path=$(git config -f .gitmodules submodule.packages.path 2>/dev/null)
		if [ "${current_path}" != ".bbx/packages" ]; then
			git config -f .gitmodules submodule.packages.path ".bbx/packages"
			git add .gitmodules
		fi
	fi
fi

# Move all other tracked root items into .bbx/
for item in ${tracked_root_items}; do
	[ "${item}" = "packages" ] && continue  # already handled above
	echo "  ${item} -> .bbx/${item}"
	git mv "${item}" ".bbx/${item}"
	if [ $? -ne 0 ]; then
		>&2 echo "Error: unable to move '${item}' to '.bbx/${item}'"
		exit 1
	fi
done

# ---- Step 5: create .gitignore ----------------------------------------------

# Read target names from the now-moved target files to add their directories
declare -a targets
for f in .bbx/target.*; do
	[ -f "${f}" ] || continue
	t=$(basename "${f}")
	t="${t#target.}"
	targets+=("${t}")
done

{
	echo "# BuildBox: generated directories (package sources and build output)"
	echo "src/"
	for t in "${targets[@]}"; do
		echo "${t}/"
	done
	echo ""
	echo "# BuildBox: profile state and per-project caches"
	echo ".bbx/.state"
	echo ".bbx/.cache/"
	echo ".bbx/.tools/"
	echo ".bbx/.trash/"
} > .gitignore

git add .gitignore

# ---- Step 6: commit the migration -------------------------------------------

migration_msg="Migrate to BuildBox 2.x: move profile into .bbx/

All project profile files are moved from the repository root into the
.bbx/ directory, as required by BuildBox 2.x. References to
\${BB_PROJECT_PROFILE_DIR} inside target profiles remain valid since
BB_PROJECT_PROFILE_DIR resolves to .bbx/ in 2.x.

$([ ${has_submodule} -eq 1 ] && echo "packages submodule path: packages -> .bbx/packages (url: ${packages_url})")
$([ ${has_submodule} -eq 0 ] && echo "No packages submodule found.")

.gitignore added for BuildBox-generated directories.

Migrated from: ${url}
Branch: ${branch}"

git commit -m "${migration_msg}"
if [ $? -ne 0 ]; then
	>&2 echo "Error: unable to create migration commit"
	exit 1
fi

# ---- Step 7: sync and initialize submodule at new path ----------------------

if [ ${has_submodule} -eq 1 ]; then
	git submodule sync
	git submodule update --init .bbx/packages
fi

# ---- Done -------------------------------------------------------------------

echo ""
echo "Migration complete."
echo ""
echo "  Directory : $(pwd)"
echo "  Branch    : master"
echo "  Targets   : ${targets[*]}"
if [ ${has_submodule} -eq 1 ]; then
	echo "  Packages  : submodule at .bbx/packages"
	echo "              ${packages_url}"
fi
echo ""
echo "Next steps:"
echo "  cd ${output_dir}"
echo "  bbx target list"
echo ""
echo "To push this project to a remote repository:"
echo "  git remote add origin <new_remote_url>"
echo "  git push -u origin master"
